# Backend Environment Variables
# Copy this file to .env and fill in your values

DATABASE_URL=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# IMPORTANT: Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Must be at least 32 characters. Never use "change-this-in-production"
JWT_SECRET_KEY=

SUPER_ADMIN_EMAIL=

# Notification configuration
# Options: mock | twilio | msg91 | pywhatkit
NOTIFICATION_PROVIDER=mock
# Options: sms | whatsapp
NOTIFICATION_CHANNEL=whatsapp

# Optional Chrome profile for Selenium WhatsApp auto-send
CHROME_USER_DATA_DIR=
CHROME_PROFILE_DIRECTORY=Default

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=+14155238886

# MSG91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=SMARTA
MSG91_WHATSAPP_NUMBER=
